# OpenRouter AI
OPENROUTER_API_KEY=your_openrouter_key

# Weibo mobile cookie
# Option A: full cookie in one line
# WEIBO_COOKIE=SUB=...; SUBP=...; SCF=...; ALF=...; SSOLoginState=...; _T_WM=...; MLOGIN=1; WEIBOCN_FROM=...; M_WEIBOCN_PARAMS=...; mweibo_short_token=...; XSRF-TOKEN=...
#
# Option B: split fields across lines, backend will join them automatically
WEIBO_COOKIE_SUB=
WEIBO_COOKIE_SUBP=
WEIBO_COOKIE_SCF=
WEIBO_COOKIE_ALF=
WEIBO_COOKIE_SSOLOGINSTATE=
WEIBO_COOKIE_T_WM=
WEIBO_COOKIE_MLOGIN=1
WEIBO_COOKIE_WEIBOCN_FROM=
WEIBO_COOKIE_M_WEIBOCN_PARAMS=
WEIBO_COOKIE_MWEIBO_SHORT_TOKEN=
WEIBO_COOKIE_XSRF_TOKEN=

# Email Notification
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
NOTIFICATION_EMAIL=your_notification_email@gmail.com

# Web Push (optional)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your_email@example.com

# Application
APP_URL=http://127.0.0.1:5173
BACKEND_PORT=8000
FRONTEND_PORT=5173

# Scheduler
MONITOR_INTERVAL_MINUTES=30
